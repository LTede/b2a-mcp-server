{
  "name": "b2a-mcp-server",
  "version": "0.1.0",
  "description": "B2A Intelligence Layer — AI agent capability discovery via MCP. Finds, matches, and orchestrates x402 services for agents that hit their ceiling.",
  "type": "module",
  "bin": {
    "b2a-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync(p.join('dist','data'),{recursive:true});fs.copyFileSync(p.join('src','data','ecosystem-registry.json'),p.join('dist','data','ecosystem-registry.json'))\"",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "x402",
    "agent",
    "capability-discovery",
    "b2a",
    "ai-agent",
    "marketplace"
  ],
  "author": "이태의 <itaeui12@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LTede/b2a-mcp-server"
  }
}
